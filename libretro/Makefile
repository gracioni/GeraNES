TARGET_NAME := geranes
CORE_SUFFIX := _libretro

CXX ?= g++
CC ?= gcc
AR ?= ar
PYTHON ?= $(shell command -v python 2>/dev/null || command -v python3 2>/dev/null)
UNAME_S := $(shell uname -s 2>/dev/null)
MINGW_STATIC_FLAGS := -static-libgcc -static-libstdc++
MINGW_STATIC_LIBS := -Wl,-Bstatic -lstdc++ -lgcc -lwinpthread -Wl,-Bdynamic

# GNU make predefines CC=cc by default. If the user did not explicitly set CC,
# derive it from CXX so MinGW cross toolchains stay consistent.
ifeq ($(origin CC), default)
CC := $(patsubst %g++,%gcc,$(CXX))
endif

SRC_DIR := ../src
CORE_DIR := $(SRC_DIR)/libretro
FLIPS_DIR := third_party/flips
DB_FILE := ../data/db.txt
EMBEDDED_DB_SRC := $(CORE_DIR)/generated/EmbeddedDbData.cpp
EMBEDDED_DB_GEN := ./gen_embedded_db.py

SOURCES_CXX := \
	$(CORE_DIR)/GeraNESLibretro.cpp \
	$(EMBEDDED_DB_SRC) \
	$(FLIPS_DIR)/libips.cpp \
	$(FLIPS_DIR)/libups.cpp \
	$(FLIPS_DIR)/libbps.cpp \
	$(FLIPS_DIR)/crc32.cpp \
	$(SRC_DIR)/signal/signal.cpp

SOURCES_C := \
	$(SRC_DIR)/zip/zip.c

OBJECTS := $(SOURCES_CXX:.cpp=.o) $(SOURCES_C:.c=.o)

INCLUDES := -I.. -I$(SRC_DIR) -I$(FLIPS_DIR)
DEFINES :=

CXXFLAGS += -std=gnu++20 -fPIC $(INCLUDES) $(DEFINES)
CFLAGS += -std=gnu11 -fPIC $(INCLUDES) $(DEFINES)
LDFLAGS +=
LIBS +=

EXT := so
SHARED := -shared

# Auto-detect Windows toolchains when platform is not explicitly set.
ifeq ($(strip $(platform)),)
	ifeq ($(OS),Windows_NT)
		EXT := dll
		SHARED := -shared
		LDFLAGS += -Wl,--no-undefined
		LDFLAGS += $(MINGW_STATIC_FLAGS)
		LIBS += $(MINGW_STATIC_LIBS)
	else ifneq (,$(findstring MINGW,$(UNAME_S)))
		EXT := dll
		SHARED := -shared
		LDFLAGS += -Wl,--no-undefined
		LDFLAGS += $(MINGW_STATIC_FLAGS)
		LIBS += $(MINGW_STATIC_LIBS)
	else ifneq (,$(findstring MSYS,$(UNAME_S)))
		EXT := dll
		SHARED := -shared
		LDFLAGS += -Wl,--no-undefined
		LDFLAGS += $(MINGW_STATIC_FLAGS)
		LIBS += $(MINGW_STATIC_LIBS)
	endif
endif

ifeq ($(platform), osx)
	EXT := dylib
	SHARED := -dynamiclib
	LDFLAGS += -Wl,-dead_strip
endif

ifneq (,$(findstring ios,$(platform)))
	EXT := dylib
	SHARED := -dynamiclib
endif

ifneq (,$(findstring win,$(platform)))
	EXT := dll
	SHARED := -shared
	LDFLAGS += -Wl,--no-undefined
	LDFLAGS += $(MINGW_STATIC_FLAGS)
	LIBS += $(MINGW_STATIC_LIBS)
endif

ifneq (,$(findstring mingw,$(platform)))
	EXT := dll
	SHARED := -shared
	LDFLAGS += -Wl,--no-undefined
	LDFLAGS += $(MINGW_STATIC_FLAGS)
	LIBS += $(MINGW_STATIC_LIBS)
endif

ifeq ($(platform), emscripten)
	EXT := bc
	SHARED :=
endif

TARGET := $(TARGET_NAME)$(CORE_SUFFIX).$(EXT)

all: $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $(SHARED) -o $@ $^ $(LDFLAGS) $(LIBS)

regen-db: $(DB_FILE) $(EMBEDDED_DB_GEN)
	@mkdir -p $(dir $(EMBEDDED_DB_SRC))
	@if command -v xxd >/dev/null 2>&1; then \
		echo "// Auto-generated by libretro/Makefile. Do not edit." > $(EMBEDDED_DB_SRC); \
		xxd -i -n geranes_libretro_embedded_db $(DB_FILE) >> $(EMBEDDED_DB_SRC); \
		echo "unsigned int geranes_libretro_embedded_db_size = geranes_libretro_embedded_db_len;" >> $(EMBEDDED_DB_SRC); \
	elif [ -n "$(PYTHON)" ]; then \
		$(PYTHON) $(EMBEDDED_DB_GEN) $(DB_FILE) $(EMBEDDED_DB_SRC); \
	else \
		echo "Need xxd or Python (python/python3) to embed db.txt"; \
		false; \
	fi

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJECTS) $(TARGET)

distclean-db:
	rm -f $(EMBEDDED_DB_SRC)

.PHONY: all clean regen-db distclean-db
